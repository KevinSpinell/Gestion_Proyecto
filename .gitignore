# ─────────────────────────────────────────────────────────────────────────────
#  Root .gitignore — covers both frontend and backend workspaces
# ─────────────────────────────────────────────────────────────────────────────

# === Dependencies ============================================================
node_modules/
frontend/node_modules/
backend/node_modules/

# === Build output ============================================================
dist/
dist-ssr/
frontend/dist/
frontend/dist-ssr/

# === Environment variables (NEVER commit .env files) =========================
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# === Logs ====================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# === Vite ====================================================================
*.local

# === Editor ===================================================================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
